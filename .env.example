POSTGRES_PASSWORD=shadowhive
NEO4J_PASSWORD=shadowhive
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Auth (enabled by default — set to false to disable)
AUTH_ENABLED=true
AUTH_MODE=jwt
# REQUIRED for production: generate with: openssl rand -base64 32
JWT_SECRET=

# Portal admin password for the fake company website admin panel (/admin)
# Default: admin123
PORTAL_ADMIN_PASSWORD=admin123

# Cowrie honeypot integration (optional — Cowrie auto-polling via REST API)
# Set an API key if Cowrie's web API requires authentication
COWRIE_API_KEY=

# SMTP for password reset emails (optional — fallback to console in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@shadowhive.local
